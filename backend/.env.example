PORT=9999
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hbms?retryWrites=true&w=majority
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# JWT (access-only)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# OTP
OTP_TTL_MINUTES=10

# Email — để trống = in OTP ra console (dev). Cắm SMTP thật: npm i nodemailer + điền dưới đây
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=HBMS <no-reply@hbms.com>

# Seed Super Admin (npm run seed)
ADMIN_EMAIL=admin@hbms.com
ADMIN_PASSWORD=Admin@123

# Google OAuth (UC-04 — để sau)
GOOGLE_CLIENT_ID=
